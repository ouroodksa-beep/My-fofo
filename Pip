from googletrans import Translator

translator = Translator()

def translate_to_arabic(text):
    brand = extract_brand(text)
    # ترجمة النص بدون البراند
    rest_of_text = text.replace(brand, "")
    translated = translator.translate(rest_of_text, dest='ar').text
    return f"{brand} {translated}"
